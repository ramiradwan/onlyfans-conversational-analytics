# ------------------------
# Python
# ------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
env/
venv/
.pytest_cache/

# ------------------------
# Environment
# ------------------------
.env

# ------------------------
# IDE settings
# ------------------------
.vscode/
.idea/

# ------------------------
# Node dependencies
# ------------------------
frontend/node_modules/

# ------------------------
# Vite build output (goes to backend)
# ------------------------
app/static/dist/*
# Keep the dist folder but ignore its contents
!app/static/dist/.gitkeep

# ------------------------
# Frontend caches and build artifacts
# ------------------------
frontend/.vite/
frontend/.swc/
frontend/.eslintcache
frontend/.ds-sync/
frontend/ds-bundle/
frontend/.design-sync/.cache/
frontend/.design-sync/learnings/
frontend/.design-sync/node_modules

# ------------------------
# Extension build outputs (if any)
# ------------------------
extension/dist/
extension/node_modules/
tools/e2e-capture/node_modules/
tools/e2e-capture/playwright-report/
tools/e2e-capture/test-results/

# ------------------------
# Logs
# ------------------------
logs/*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ------------------------
# Style Dictionary generated tokens
# ------------------------
frontend/src/theme/generated/*
!frontend/src/theme/generated/tokens.ts
