# === App Settings ===
ENVIRONMENT=production
WEBSOCKET_AUTH_MODE=local_session
WEBSOCKET_BIND_HOST=127.0.0.1
LOCAL_SESSION_BOOTSTRAP_TOKEN=replace-with-at-least-32-random-characters
LOCAL_PRINCIPAL_ID=replace-with-provisioned-principal
LOCAL_CREATOR_ACCOUNT_ID=replace-with-authorized-account
LOCAL_PLATFORM_CREATOR_ID=replace-with-independently-verified-platform-id
LOCAL_BRIDGE_ROLE=creator
SECURITY_SIGNING_SECRET=replace-with-at-least-32-random-characters

# === Local SQLite ===
CANONICAL_PERSISTENCE_BACKEND=sqlite
CANONICAL_DATABASE_PATH=canonical.sqlite3
PROJECTION_DATABASE_PATH=projections.sqlite3

# === Extension Bridge ===
EXTENSION_ID=

# === NLP Models ===
NLP_MODEL_PATH=
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# === Process-local event distribution ===
BROADCAST_URL=memory://
