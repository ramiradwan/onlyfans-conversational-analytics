    },
    "GraphExplorerView": {
      "cardMode": "single",
      "viewport": "900x560"
    },
    "KpiCard": {
      "cardMode": "column"
    },
    "KpiCardSkeleton": {
      "cardMode": "column"
    },
    "KpiPlaceholder": {
      "cardMode": "column"
    },
    "OperatorInboxView": {
      "cardMode": "single",
      "viewport": "1100x720"
    }
  }
