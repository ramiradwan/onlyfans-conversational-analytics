  "dtsPropsFor": {
    "AnalyticsView": "  // No props.",
    "App": "  // No props.",
    "AppAppBar": "  drawerWidth: number;\n  onDrawerToggle: () => void;",
    "AppDrawer": "  drawerWidth: number;\n  mobileOpen: boolean;\n  onDrawerToggle: () => void;",
    "AppShell": "  // No props.",
    "AsyncContent": "  isLoading: boolean;\n  data: unknown[] | null | undefined;\n  placeholder: React.ReactNode;\n  emptyMessage: React.ReactNode;\n  render: (data: unknown[]) => React.ReactNode;",
    "ChartPlaceholder": "  height?: number;",
    "ChatListPane": "  conversations: ReadonlyArray<{\n    conversation_id: string;\n    platform_user_id: string;\n    display_name: string | null;\n    unread_count: number;\n    last_message_at: string | null;\n    messages: Array<{\n      message_id: string;\n      text: string;\n      sent_at: string;\n      direction: 'inbound' | 'outbound';\n      sentiment: 'positive' | 'neutral' | 'negative' | 'unknown';\n    }>;\n  }>;\n  isLoading: boolean;\n  onSelectConversation: (conversationId: string) => void;\n  selectedConversationId: string | null;",
    "ChatListPlaceholder": "  rows?: number;",
    "CreatorDashboardView": "  // No props.",
    "Fan360Placeholder": "  // No props.",
    "GlobalLoader": "  // No props.",
    "GraphExplorerView": "  // No props.",
    "HorizontalBarsPlaceholder": "  bars?: number;",
    "KpiCard": "  title: string;\n  value: string | number;\n  isLoading?: boolean;\n  grow?: boolean;",
    "KpiCardSkeleton": "  grow?: boolean;",
    "KpiPlaceholder": "  // No props.",
    "MessageBubble": "  message: {\n    message_id: string;\n    text: string;\n    sent_at: string;\n    direction: 'inbound' | 'outbound';\n    sentiment: 'positive' | 'neutral' | 'negative' | 'unknown';\n  };",
    "MessageFlagIcon": "  sentiment: 'positive' | 'neutral' | 'negative' | 'unknown';\n  context?: 'latest' | 'message';",
    "MessageStreamPane": "  conversation: {\n    conversation_id: string;\n    platform_user_id: string;\n    display_name: string | null;\n    unread_count: number;\n    last_message_at: string | null;\n    messages: Array<{\n      message_id: string;\n      text: string;\n      sent_at: string;\n      direction: 'inbound' | 'outbound';\n      sentiment: 'positive' | 'neutral' | 'negative' | 'unknown';\n    }>;\n  } | null;\n  isLoading: boolean;\n  isOnline: boolean;",
    "MessageStreamPlaceholder": "  bubbles?: number;",
    "OperatorInboxView": "  store?: {\n    getState(): Readonly<Record<string, unknown>>;\n    subscribe(listener: () => void): () => void;\n  };",
    "Panel": "  children: React.ReactNode;\n  sx?: unknown;",
    "QueryInput": "  onSend: (text: string) => void;\n  disabled?: boolean;",
    "QueryResponseBubble": "  response: {\n    id: string;\n    question: string;\n    answer?: string;\n    gremlinQuery?: string;\n    result?: Record<string, unknown> | unknown[];\n  };",
    "QueryResponseBubbleSkeleton": "  // No props.",
    "TablePlaceholder": "  rows?: number;",
    "ThemeToggle": "  // No props.",
    "UserQueryBubble": "  text: string;"
  },
  "provider": {
    "component": "ThemeProvider",
    "props": {
      "theme": {
        "$ref": "theme"
      },
      "defaultMode": "light",
      "disableTransitionOnChange": true
    }
  },
  "overrides": {
    "App": {
      "cardMode": "single",
      "viewport": "960x640"
