{
  "_meta": {
    "name": "Bridge Design System",
    "version": "7.5.0",
    "governance": "Tier 1 primitives feed Tier 2 semantic aliases and Tier 3 component overrides."
  },
  "tier1": {
    "brandPalette": {
      "groundedTech": { "primary": "#2563EB", "deep": "#0062E0", "light": "#60A5FA" },
      "humanConnection": { "primary": "#A47864", "dark": "#8B5E4A", "light": "#C08467" },
      "optimisticAccent": { "primary": "#FACC15", "dark": "#CA8A04" },
      "calmClear": { "etherealBlue": "#E0F0FF" },
      "feedback": {
        "success": "#15803D",
        "successDark": "#4ADE80",
        "warning": "#CA8A04",
        "warningDark": "#FACC15",
        "error": "#B91C1C",
        "errorDark": "#F87171"
      },
      "neutral": {
        "white": "#FFFFFF",
        "black": "#000000",
        "50": "#F9FAFB",
        "100": "#F3F4F6",
        "200": "#E5E7EB",
        "300": "#D1D5DB",
        "400": "#9CA3AF",
        "500": "#6B7280",
        "600": "#4B5563",
        "700": "#374151",
        "800": "#1F2937",
        "850": "#1E1E1E",
        "875": "#1A1A1A",
        "900": "#111827",
        "950": "#121212"
      }
    },
    "brandTypography": {
      "fontFamily": "\"Inter\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
      "fontFamilyMono": "ui-monospace, SFMono-Regular, Menlo, monospace",
      "weights": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 },
      "scale": {
        "h1": "2.5rem",
        "h2": "2rem",
        "h3": "1.75rem",
        "h4": "1.5rem",
        "h5": "1.25rem",
        "h6": "1.125rem",
        "body1": "1rem",
        "body2": "0.875rem",
        "caption": "0.75rem"
      }
    },
    "layout": {
      "spacingUnit": 8,
      "radius": { "small": 4, "medium": 8, "large": 12, "message": 16, "pill": 999 },
      "breakpoints": { "xs": 0, "sm": 600, "md": 900, "lg": 1200, "xl": 1536 },
      "zIndex": { "appBar": 1100, "drawer": 1200, "modal": 1300, "snackbar": 1400, "tooltip": 1500 }
    },
    "effects": {
      "borders": { "thin": "1px" },
      "focus": { "width": "2px", "offset": "2px" },
      "glassmorphism": { "backdropFilter": "blur(5px)" },
      "motion": { "duration": "200ms", "easing": "cubic-bezier(0.4, 0, 0.2, 1)" }
    }
  },
  "tier2": {
    "colorSchemes": {
      "light": {
        "mode": "light",
        "contrastThreshold": 4.5,
        "primary": { "main": "{tier1.brandPalette.groundedTech.deep}" },
        "secondary": { "main": "{tier1.brandPalette.humanConnection.primary}" },
        "accent": { "main": "{tier1.brandPalette.optimisticAccent.primary}" },
        "calm": { "main": "{tier1.brandPalette.groundedTech.primary}" },
        "success": { "main": "{tier1.brandPalette.feedback.success}" },
        "warning": { "main": "{tier1.brandPalette.feedback.warning}" },
        "error": { "main": "{tier1.brandPalette.feedback.error}" },
        "info": { "main": "{tier1.brandPalette.groundedTech.deep}" },
        "background": {
          "default": "{tier1.brandPalette.neutral.50}",
          "paper": "{tier1.brandPalette.neutral.white}"
        },
        "text": {
          "primary": "{tier1.brandPalette.neutral.900}",
          "secondary": "{tier1.brandPalette.neutral.600}",
          "disabled": "{tier1.brandPalette.neutral.500}"
        },
        "divider": "rgba(17, 24, 39, 0.12)",
        "action": {
          "hover": "rgba(0, 98, 224, 0.06)",
          "selected": "rgba(0, 98, 224, 0.12)",
          "disabled": "rgba(17, 24, 39, 0.30)"
        },
        "placeholder": "{tier1.brandPalette.neutral.200}",
        "surface": {
          "subtle": "{tier1.brandPalette.neutral.100}",
          "glass": "rgba(255, 255, 255, 0.72)",
          "chartInsetShadow": "inset 0 0 3px rgba(0, 0, 0, 0.08)"
        },
        "communication": {
          "incomingSurface": "{tier1.brandPalette.neutral.white}",
          "incomingBorder": "{tier1.brandPalette.neutral.300}",
          "outgoingSurface": "#DBEAFE",
          "outgoingBorder": "#93C5FD"
        },
        "chart": {
          "sentiment": "{tier1.brandPalette.groundedTech.deep}",
          "volume": "{tier1.brandPalette.optimisticAccent.dark}",
          "neutral": "{tier1.brandPalette.neutral.500}"
        }
      },
      "dark": {
        "mode": "dark",
        "contrastThreshold": 4.5,
        "primary": { "main": "{tier1.brandPalette.groundedTech.light}" },
        "secondary": { "main": "{tier1.brandPalette.humanConnection.light}" },
        "accent": { "main": "{tier1.brandPalette.optimisticAccent.primary}" },
        "calm": { "main": "{tier1.brandPalette.groundedTech.light}" },
        "success": { "main": "{tier1.brandPalette.feedback.successDark}" },
        "warning": { "main": "{tier1.brandPalette.feedback.warningDark}" },
        "error": { "main": "{tier1.brandPalette.feedback.errorDark}" },
        "info": { "main": "{tier1.brandPalette.groundedTech.light}" },
        "background": {
          "default": "{tier1.brandPalette.neutral.950}",
          "paper": "{tier1.brandPalette.neutral.850}"
        },
        "text": {
          "primary": "{tier1.brandPalette.neutral.100}",
          "secondary": "{tier1.brandPalette.neutral.300}",
          "disabled": "{tier1.brandPalette.neutral.400}"
        },
        "divider": "rgba(255, 255, 255, 0.14)",
        "action": {
          "hover": "rgba(96, 165, 250, 0.10)",
          "selected": "rgba(96, 165, 250, 0.18)",
          "disabled": "rgba(255, 255, 255, 0.30)"
        },
        "placeholder": "{tier1.brandPalette.neutral.700}",
        "surface": {
          "subtle": "{tier1.brandPalette.neutral.875}",
          "glass": "rgba(18, 18, 18, 0.78)",
          "chartInsetShadow": "inset 0 0 3px rgba(255, 255, 255, 0.10)"
        },
        "communication": {
          "incomingSurface": "{tier1.brandPalette.neutral.800}",
          "incomingBorder": "{tier1.brandPalette.neutral.700}",
          "outgoingSurface": "#172554",
          "outgoingBorder": "#1D4ED8"
        },
        "chart": {
          "sentiment": "{tier1.brandPalette.groundedTech.light}",
          "volume": "{tier1.brandPalette.optimisticAccent.primary}",
          "neutral": "{tier1.brandPalette.neutral.400}"
        }
      }
    },
    "typography": {
      "fontFamily": "{tier1.brandTypography.fontFamily}",
      "h1": { "fontSize": "{tier1.brandTypography.scale.h1}", "fontWeight": "{tier1.brandTypography.weights.bold}", "lineHeight": 1.2 },
      "h2": { "fontSize": "{tier1.brandTypography.scale.h2}", "fontWeight": "{tier1.brandTypography.weights.bold}", "lineHeight": 1.2 },
      "h3": { "fontSize": "{tier1.brandTypography.scale.h3}", "fontWeight": "{tier1.brandTypography.weights.semibold}", "lineHeight": 1.3 },
      "h4": { "fontSize": "{tier1.brandTypography.scale.h4}", "fontWeight": "{tier1.brandTypography.weights.semibold}", "lineHeight": 1.35 },
      "h5": { "fontSize": "{tier1.brandTypography.scale.h5}", "fontWeight": "{tier1.brandTypography.weights.semibold}", "lineHeight": 1.4 },
      "h6": { "fontSize": "{tier1.brandTypography.scale.h6}", "fontWeight": "{tier1.brandTypography.weights.semibold}", "lineHeight": 1.45 },
      "subtitle1": { "fontSize": "{tier1.brandTypography.scale.body1}", "fontWeight": "{tier1.brandTypography.weights.semibold}", "lineHeight": 1.5 },
      "subtitle2": { "fontSize": "{tier1.brandTypography.scale.body2}", "fontWeight": "{tier1.brandTypography.weights.semibold}", "lineHeight": 1.43 },
      "body1": { "fontSize": "{tier1.brandTypography.scale.body1}", "fontWeight": "{tier1.brandTypography.weights.regular}", "lineHeight": 1.5 },
      "body2": { "fontSize": "{tier1.brandTypography.scale.body2}", "fontWeight": "{tier1.brandTypography.weights.regular}", "lineHeight": 1.43 },
      "caption": { "fontSize": "{tier1.brandTypography.scale.caption}", "fontWeight": "{tier1.brandTypography.weights.regular}", "lineHeight": 1.66 },
      "button": { "fontSize": "{tier1.brandTypography.scale.body2}", "fontWeight": "{tier1.brandTypography.weights.semibold}", "textTransform": "none" }
    },
    "shape": { "borderRadius": "{tier1.layout.radius.small}" }
  },
  "tier3": {
    "MuiButton": { "borderRadius": "{tier1.layout.radius.large}", "activeScale": 0.97 },
    "MuiPaper": { "borderRadius": "{tier1.layout.radius.large}" },
    "MuiListItemButton": { "activeScale": 0.97 },
    "inbox": {
      "bubbleRadius": "{tier1.layout.radius.message}",
      "bubbleMaxWidth": "44rem",
      "bubbleWidth": "78%",
      "conversationPaneMinWidth": "18rem"
    },
    "skeleton": {
      "chart": { "minHeight": 200, "maxHeight": "40vh", "width": "100%", "variant": "rectangular", "animation": "wave" },
      "kpiTitle": { "variant": "text", "sx": { "fontSize": "0.875rem", "width": "60%" }, "animation": "wave" },
      "kpiValue": { "variant": "text", "sx": { "fontSize": "1.5rem", "width": "40%", "mt": 0.5 }, "animation": "wave" },
      "table": { "variant": "rectangular", "width": "100%", "minHeight": 150, "maxHeight": "30vh", "animation": "wave" },
      "avatar": { "variant": "circular", "width": 40, "height": 40, "animation": "wave" }
    }
  }
}
