{
  "_meta": {
    "name": "Bridge Design System",
    "version": "8.0.0",
    "governance": "Tier 1 primitives feed Tier 2 semantic aliases and Tier 3 component overrides."
  },
  "tier1": {
    "brandPalette": {
      "groundedTech": { "primary": "#5B57F2", "deep": "#4340C9", "light": "#8B87FF" },
      "humanConnection": { "primary": "#8B5CF6", "dark": "#6D3DD0", "light": "#A78BFA" },
      "optimisticAccent": { "primary": "#8B5CF6", "dark": "#6D3DD0" },
      "calmClear": { "etherealBlue": "#EEEEF5" },
      "feedback": {
        "success": "#008300",
        "successDark": "#4CAF50",
        "warning": "#A85C00",
        "warningDark": "#F5B547",
        "error": "#C9363E",
        "errorDark": "#E66767"
      },
      "neutral": {
        "white": "#FFFFFF",
        "black": "#000000",
        "50": "#F4F4F9",
        "100": "#EEEEF5",
        "200": "#E8E8F0",
        "300": "#D8D7E2",
        "400": "#9B99A8",
        "500": "#6F6D7E",
        "550": "#6B6979",
        "600": "#5C5A69",
        "700": "#33333F",
        "800": "#24242F",
        "850": "#1E1E28",
        "875": "#17171F",
        "900": "#17161F",
        "950": "#08080C"
      },
      "dataViz": {
        "light": {
          "blue": "#0094A8",
          "green": "#008300",
          "magenta": "#CA7BBD",
          "yellow": "#A98F00",
          "aqua": "#1DB07B",
          "orange": "#DC5C2B",
          "violet": "#1B3BAA",
          "red": "#8F0731"
        },
        "dark": {
          "blue": "#00ABC1",
          "green": "#008300",
          "magenta": "#DF92D1",
          "yellow": "#EDCA19",
          "aqua": "#009F6D",
          "orange": "#DD480D",
          "violet": "#7E7FF3",
          "red": "#C83452"
        }
      }
    },
    "brandTypography": {
      "fontFamily": "\"Inter\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
      "fontFamilyMono": "ui-monospace, SFMono-Regular, Menlo, monospace",
      "weights": { "regular": 400, "medium": 600, "semibold": 600, "bold": 700, "extrabold": 700 },
      "scale": {
        "h1": "2.5rem",
        "h2": "2rem",
        "h3": "1.75rem",
        "h4": "1.6rem",
        "h5": "1.25rem",
        "h6": "1rem",
        "body1": "1rem",
        "body2": "0.875rem",
        "caption": "0.75rem"
      }
    },
    "layout": {
      "spacingUnit": 8,
      "radius": { "small": 10, "medium": 14, "large": 18, "message": 16, "pill": 999 },
      "shell": { "desktopRailWidth": 76, "mobileDrawerWidth": 264, "headerHeight": 72, "dashboardMaxWidth": 1320 },
      "breakpoints": { "xs": 0, "sm": 600, "md": 900, "lg": 1200, "xl": 1536 },
      "zIndex": { "appBar": 1200, "drawer": 1100, "modal": 1300, "snackbar": 1400, "tooltip": 1500 }
    },
    "effects": {
      "borders": { "thin": "1px" },
      "focus": { "width": "2px", "offset": "2px" },
      "glassmorphism": { "backdropFilter": "blur(16px) saturate(160%)" },
      "elevation": {
        "light": "0 1px 2px rgba(17, 17, 26, 0.04), 0 12px 32px -14px rgba(17, 17, 26, 0.16)",
        "dark": "0 2px 4px rgba(0, 0, 0, 0.50), 0 20px 48px -24px rgba(0, 0, 0, 0.85)"
      },
      "rim": {
        "light": "linear-gradient(180deg, rgba(17, 17, 26, 0.10), rgba(17, 17, 26, 0.02) 42%, rgba(17, 17, 26, 0))",
        "dark": "linear-gradient(180deg, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0.03) 42%, rgba(255, 255, 255, 0))"
      },
      "motion": { "duration": "200ms", "easing": "cubic-bezier(0.4, 0, 0.2, 1)" }
    }
  },
  "tier2": {
    "colorSchemes": {
      "light": {
        "mode": "light",
        "contrastThreshold": 4.5,
        "primary": { "main": "{tier1.brandPalette.groundedTech.primary}" },
        "secondary": { "main": "{tier1.brandPalette.humanConnection.primary}" },
        "accent": { "main": "{tier1.brandPalette.optimisticAccent.primary}" },
        "calm": { "main": "{tier1.brandPalette.groundedTech.primary}" },
        "success": { "main": "{tier1.brandPalette.feedback.success}" },
        "warning": { "main": "{tier1.brandPalette.feedback.warning}" },
        "error": { "main": "{tier1.brandPalette.feedback.error}" },
        "info": { "main": "{tier1.brandPalette.dataViz.light.blue}" },
        "background": { "default": "{tier1.brandPalette.neutral.50}", "paper": "{tier1.brandPalette.neutral.white}" },
        "text": { "primary": "{tier1.brandPalette.neutral.900}", "secondary": "{tier1.brandPalette.neutral.600}", "muted": "{tier1.brandPalette.neutral.550}", "disabled": "{tier1.brandPalette.neutral.400}" },
        "divider": "rgba(20, 18, 33, 0.06)",
        "action": { "hover": "rgba(20, 18, 33, 0.04)", "selected": "rgba(91, 87, 242, 0.10)", "disabled": "rgba(20, 18, 33, 0.30)" },
        "placeholder": "{tier1.brandPalette.neutral.200}",
        "surface": {
          "subtle": "{tier1.brandPalette.neutral.100}",
          "glass": "rgba(255, 255, 255, 0.76)",
          "elevation": "{tier1.effects.elevation.light}",
          "rim": "{tier1.effects.rim.light}"
        },
        "communication": { "incomingSurface": "{tier1.brandPalette.neutral.white}", "incomingBorder": "{tier1.brandPalette.neutral.300}", "outgoingSurface": "#E8E7FF", "outgoingBorder": "#B8B5FF" },
        "chart": {
          "sentiment": "{tier1.brandPalette.groundedTech.primary}",
          "volume": "{tier1.brandPalette.humanConnection.primary}",
          "neutral": "{tier1.brandPalette.neutral.400}",
          "positive": "{tier1.brandPalette.dataViz.light.green}",
          "negative": "{tier1.brandPalette.dataViz.light.red}",
          "unknown": "{tier1.brandPalette.dataViz.light.violet}",
          "categorical1": "{tier1.brandPalette.dataViz.light.blue}",
          "categorical2": "{tier1.brandPalette.dataViz.light.green}",
          "categorical3": "{tier1.brandPalette.dataViz.light.magenta}",
          "categorical4": "{tier1.brandPalette.dataViz.light.yellow}",
          "categorical5": "{tier1.brandPalette.dataViz.light.aqua}",
          "categorical6": "{tier1.brandPalette.dataViz.light.orange}",
          "categorical7": "{tier1.brandPalette.dataViz.light.violet}",
          "categorical8": "{tier1.brandPalette.dataViz.light.red}",
          "opportunity": "{tier1.brandPalette.dataViz.light.yellow}",
          "grid": "rgba(17, 24, 39, 0.14)"
        }
      },
      "dark": {
        "mode": "dark",
        "contrastThreshold": 4.5,
        "primary": { "main": "{tier1.brandPalette.groundedTech.light}" },
        "secondary": { "main": "{tier1.brandPalette.humanConnection.light}" },
        "accent": { "main": "{tier1.brandPalette.humanConnection.light}" },
        "calm": { "main": "{tier1.brandPalette.groundedTech.light}" },
        "success": { "main": "{tier1.brandPalette.feedback.successDark}" },
        "warning": { "main": "{tier1.brandPalette.feedback.warningDark}" },
        "error": { "main": "{tier1.brandPalette.feedback.errorDark}" },
        "info": { "main": "{tier1.brandPalette.dataViz.dark.blue}" },
        "background": { "default": "{tier1.brandPalette.neutral.950}", "paper": "{tier1.brandPalette.neutral.875}" },
        "text": { "primary": "#F4F3F9", "secondary": "#B6B4C4", "muted": "{tier1.brandPalette.neutral.400}", "disabled": "{tier1.brandPalette.neutral.500}" },
        "divider": "rgba(255, 255, 255, 0.07)",
        "action": { "hover": "rgba(255, 255, 255, 0.05)", "selected": "rgba(139, 135, 255, 0.16)", "disabled": "rgba(255, 255, 255, 0.30)" },
        "placeholder": "{tier1.brandPalette.neutral.800}",
        "surface": {
          "subtle": "{tier1.brandPalette.neutral.850}",
          "glass": "rgba(9, 9, 14, 0.78)",
          "elevation": "{tier1.effects.elevation.dark}",
          "rim": "{tier1.effects.rim.dark}"
        },
        "communication": { "incomingSurface": "{tier1.brandPalette.neutral.850}", "incomingBorder": "{tier1.brandPalette.neutral.700}", "outgoingSurface": "#25205C", "outgoingBorder": "#5952C7" },
        "chart": {
          "sentiment": "{tier1.brandPalette.groundedTech.light}",
          "volume": "{tier1.brandPalette.humanConnection.light}",
          "neutral": "{tier1.brandPalette.neutral.700}",
          "positive": "{tier1.brandPalette.dataViz.dark.green}",
          "negative": "{tier1.brandPalette.dataViz.dark.red}",
          "unknown": "{tier1.brandPalette.dataViz.dark.violet}",
          "categorical1": "{tier1.brandPalette.dataViz.dark.blue}",
          "categorical2": "{tier1.brandPalette.dataViz.dark.green}",
          "categorical3": "{tier1.brandPalette.dataViz.dark.magenta}",
          "categorical4": "{tier1.brandPalette.dataViz.dark.yellow}",
          "categorical5": "{tier1.brandPalette.dataViz.dark.aqua}",
          "categorical6": "{tier1.brandPalette.dataViz.dark.orange}",
          "categorical7": "{tier1.brandPalette.dataViz.dark.violet}",
          "categorical8": "{tier1.brandPalette.dataViz.dark.red}",
          "opportunity": "{tier1.brandPalette.dataViz.dark.yellow}",
          "grid": "rgba(255, 255, 255, 0.16)"
        }
      }
    },
    "typography": {
      "fontFamily": "{tier1.brandTypography.fontFamily}",
      "h1": { "fontSize": "{tier1.brandTypography.scale.h1}", "fontWeight": "{tier1.brandTypography.weights.extrabold}", "lineHeight": 1.15, "letterSpacing": "-0.03em" },
      "h2": { "fontSize": "{tier1.brandTypography.scale.h2}", "fontWeight": "{tier1.brandTypography.weights.extrabold}", "lineHeight": 1.2, "letterSpacing": "-0.03em" },
      "h3": { "fontSize": "{tier1.brandTypography.scale.h3}", "fontWeight": "{tier1.brandTypography.weights.extrabold}", "lineHeight": 1.25, "letterSpacing": "-0.025em" },
      "h4": { "fontSize": "{tier1.brandTypography.scale.h4}", "fontWeight": "{tier1.brandTypography.weights.extrabold}", "lineHeight": 1.3, "letterSpacing": "-0.03em" },
      "h5": { "fontSize": "{tier1.brandTypography.scale.h5}", "fontWeight": "{tier1.brandTypography.weights.bold}", "lineHeight": 1.35, "letterSpacing": "-0.02em" },
      "h6": { "fontSize": "{tier1.brandTypography.scale.h6}", "fontWeight": "{tier1.brandTypography.weights.bold}", "lineHeight": 1.4, "letterSpacing": "-0.01em" },
      "subtitle1": { "fontSize": "{tier1.brandTypography.scale.body1}", "fontWeight": "{tier1.brandTypography.weights.semibold}", "lineHeight": 1.5 },
      "subtitle2": { "fontSize": "{tier1.brandTypography.scale.body2}", "fontWeight": "{tier1.brandTypography.weights.semibold}", "lineHeight": 1.43 },
      "body1": { "fontSize": "{tier1.brandTypography.scale.body1}", "fontWeight": "{tier1.brandTypography.weights.regular}", "lineHeight": 1.5 },
      "body2": { "fontSize": "{tier1.brandTypography.scale.body2}", "fontWeight": "{tier1.brandTypography.weights.regular}", "lineHeight": 1.43 },
      "caption": { "fontSize": "{tier1.brandTypography.scale.caption}", "fontWeight": "{tier1.brandTypography.weights.regular}", "lineHeight": 1.66 },
      "button": { "fontSize": "{tier1.brandTypography.scale.body2}", "fontWeight": "{tier1.brandTypography.weights.semibold}", "textTransform": "none" }
    },
    "shape": { "borderRadius": "{tier1.layout.radius.small}" }
  },
  "tier3": {
    "MuiButton": { "borderRadius": "{tier1.layout.radius.medium}", "activeScale": 0.97 },
    "MuiPaper": { "borderRadius": "{tier1.layout.radius.large}" },
    "MuiListItemButton": { "activeScale": 0.97 },
    "shell": { "desktopRailWidth": "{tier1.layout.shell.desktopRailWidth}", "mobileDrawerWidth": "{tier1.layout.shell.mobileDrawerWidth}", "headerHeight": "{tier1.layout.shell.headerHeight}", "dashboardMaxWidth": "{tier1.layout.shell.dashboardMaxWidth}" },
    "inbox": { "bubbleRadius": "{tier1.layout.radius.message}", "bubbleMaxWidth": "44rem", "bubbleWidth": "78%", "conversationPaneMinWidth": "18rem", "insightsPaneMinWidth": "17rem" },
    "analytics": {
      "chartHeight": 280,
      "markSize": 8,
      "markHitTarget": 24,
      "barThickness": 12,
      "barGap": 2,
      "dataEndRadius": 4,
      "metricIconSize": 48,
      "refreshOpacity": 0.56
    },
    "skeleton": {
      "chart": { "minHeight": 200, "maxHeight": "40vh", "width": "100%", "variant": "rectangular", "animation": false },
      "kpiTitle": { "variant": "text", "sx": { "fontSize": "0.875rem", "width": "60%" }, "animation": false },
      "kpiValue": { "variant": "text", "sx": { "fontSize": "1.5rem", "width": "40%", "mt": 0.5 }, "animation": false },
      "table": { "variant": "rectangular", "width": "100%", "minHeight": 150, "maxHeight": "30vh", "animation": false },
      "avatar": { "variant": "circular", "width": 40, "height": 40, "animation": false }
    }
  }
}
